meta {
  name: PATCH /service/<id>
  type: http
  seq: 4
}

patch {
  url: {{HREF}}
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json-patch+json
}

body:json {
  [
    {
      "op": "replace",
      "path": "/state",
      "value": "inactive"
    }
  ]
}

settings {
  encodeUrl: true
  timeout: 0
}
